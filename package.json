{
  "private": true,
  "workspaces": [
    "apps/web-extension",
    "packages/react-grab"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm --filter react-grab build && pnpm --filter @react-grab/web-extension build",
    "dev": "pnpm --filter react-grab dev",
    "typecheck": "pnpm --filter react-grab typecheck",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "extension:dev": "pnpm --filter web-extension dev",
    "extension:build": "pnpm --filter web-extension build",
    "mock:agent-endpoint": "node scripts/mock-agent-endpoint.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@voidzero-dev/vite-plus-core": "^0.1.20",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "spawn-sync",
      "unrs-resolver"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core",
      "vitest": "npm:@voidzero-dev/vite-plus-test",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
